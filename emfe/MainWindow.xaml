<Window x:Class="emfe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:emfe"
        Title="emfe - Emulator Frontend" Width="1100" Height="750"
        Background="{DynamicResource ThemeWindowBg}"
        Foreground="{DynamicResource ThemeForeground}">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{x:Static local:MainWindow.RunCommand}"/>
        <KeyBinding Key="F5" Modifiers="Shift" Command="{x:Static local:MainWindow.StopCommand}"/>
        <KeyBinding Key="F10" Command="{x:Static local:MainWindow.StepCommand}"/>
        <KeyBinding Key="F11" Command="{x:Static local:MainWindow.StepOverCommand}"/>
        <KeyBinding Key="F11" Modifiers="Shift" Command="{x:Static local:MainWindow.StepOutCommand}"/>
        <KeyBinding Key="E" Modifiers="Control" Command="{x:Static local:MainWindow.LoadElfCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <Style x:Key="ToolBarBtnStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="PanelHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeAccent}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0,8,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem x:Name="MenuLoadElf" Header="Open _ELF..." InputGestureText="Ctrl+E" Click="OnLoadElf"/>
                <MenuItem x:Name="MenuLoadSrec" Header="Open _S-Record..." InputGestureText="Ctrl+S" Click="OnLoadSrec"/>
                <MenuItem x:Name="MenuLoadBinary" Header="Open _Binary..." Click="OnLoadBinary"/>
                <Separator/>
                <MenuItem Header="S_witch Plugin..." Click="OnSwitchPlugin"/>
            </MenuItem>
            <MenuItem Header="_Run">
                <MenuItem Header="_Run" InputGestureText="F5" Click="OnRun"/>
                <MenuItem Header="_Stop" InputGestureText="Shift+F5" Click="OnStop"/>
                <MenuItem Header="S_tep" InputGestureText="F10" Click="OnStep"/>
                <MenuItem x:Name="MenuStepOver" Header="Step _Over" InputGestureText="F11" Click="OnStepOver"/>
                <MenuItem x:Name="MenuStepOut" Header="Step O_ut" InputGestureText="Shift+F11" Click="OnStepOut"/>
                <Separator/>
                <MenuItem Header="Re_set" Click="OnReset"/>
                <MenuItem Header="_Full Reset" Click="OnFullReset"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Console" Click="OnToggleConsole"/>
                <MenuItem Header="_Breakpoints..." Click="OnOpenBreakpoints"/>
                <MenuItem x:Name="MenuCallStack" Header="Call _Stack..." Click="OnOpenCallStack"/>
                <MenuItem x:Name="MenuFramebuffer" Header="_Framebuffer..." Click="OnOpenFramebuffer"/>
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="_Emulator Settings..." Click="OnOpenSettings"/>
            </MenuItem>
        </Menu>

        <!-- Row 1: Toolbar -->
        <ToolBar Grid.Row="1" Band="0" BandIndex="0">
            <Button x:Name="BtnRun" Content="Run (F5)" Style="{StaticResource ToolBarBtnStyle}" Click="OnRun"/>
            <Button x:Name="BtnStop" Content="Stop (Shift+F5)" Style="{StaticResource ToolBarBtnStyle}" Click="OnStop" IsEnabled="False"/>
            <Button x:Name="BtnStep" Content="Step (F10)" Style="{StaticResource ToolBarBtnStyle}" Click="OnStep"/>
            <Button x:Name="BtnStepOver" Content="Step Over (F11)" Style="{StaticResource ToolBarBtnStyle}" Click="OnStepOver"/>
            <Button x:Name="BtnStepOut" Content="Step Out (Shift+F11)" Style="{StaticResource ToolBarBtnStyle}" Click="OnStepOut"/>
            <Button x:Name="BtnReset" Content="Reset" Style="{StaticResource ToolBarBtnStyle}" Click="OnReset"/>
            <Button x:Name="BtnFullReset" Content="Full Reset" Style="{StaticResource ToolBarBtnStyle}" Click="OnFullReset"/>
            <Separator/>
            <TextBlock x:Name="CyclesText" Text="Cycles: 0" FontFamily="Consolas" FontSize="13"
                       VerticalAlignment="Center" Margin="8,0"/>
            <TextBlock x:Name="StopReasonText" Text="" FontFamily="Consolas" FontSize="13"
                       VerticalAlignment="Center" Margin="8,0"
                       Foreground="{DynamicResource ThemeWarningFg}"/>
        </ToolBar>

        <!-- Row 2: Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Disassembly (top 3*) + Memory dump (bottom 2*) -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>

                <!-- Disassembly Panel -->
                <Border Grid.Row="0" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Margin="2">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                    Background="{DynamicResource ThemePanelBg}" Height="28">
                            <TextBlock Text="Disassembly" Style="{StaticResource PanelHeaderStyle}"/>
                            <TextBlock Text="Address:" FontFamily="Consolas" FontSize="13"
                                       VerticalAlignment="Center" Margin="4,0,4,0"/>
                            <TextBox x:Name="DisasmAddrBox" Width="80" FontFamily="Consolas" FontSize="13"
                                     VerticalContentAlignment="Center"/>
                            <Button Content="Go" Style="{StaticResource ToolBarBtnStyle}" Click="OnDisasmGo"/>
                            <CheckBox x:Name="FollowPCCheck" Content="Follow PC" IsChecked="True"
                                      VerticalAlignment="Center" Margin="8,0,4,0" FontSize="12"/>
                            <Border Width="1" Margin="4,2"
                                    Background="{DynamicResource ThemeSeparator}"/>
                            <TextBlock x:Name="LoadedFileText" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{DynamicResource ThemeDimFg}" Margin="4,0,0,0"/>
                        </StackPanel>
                        <ListBox x:Name="DisasmList" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="13"
                                 HorizontalContentAlignment="Stretch"
                                 SelectionMode="Extended"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 MouseDoubleClick="OnDisasmDoubleClick">
                            <ListBox.InputBindings>
                                <KeyBinding Key="C" Modifiers="Control" Command="ApplicationCommands.Copy"/>
                            </ListBox.InputBindings>
                            <ListBox.CommandBindings>
                                <CommandBinding Command="ApplicationCommands.Copy" Executed="OnDisasmCopy"/>
                            </ListBox.CommandBindings>
                            <ListBox.ContextMenu>
                                <ContextMenu Opened="OnDisasmContextOpened">
                                    <MenuItem Header="キャンセル" Click="OnDisasmMenuCancel"/>
                                    <Separator/>
                                    <MenuItem x:Name="DisasmMenuRunToHere"
                                              Header="ここまで実行"
                                              Click="OnDisasmMenuRunToHere"/>
                                    <MenuItem x:Name="DisasmMenuSetPc"
                                              Header="現在のアドレスを PC に設定"
                                              Click="OnDisasmMenuSetPc"/>
                                    <Separator/>
                                    <MenuItem x:Name="DisasmMenuCopy"
                                              Header="選択範囲をコピー (Ctrl+C)"
                                              Click="OnDisasmMenuCopy"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- Memory Dump Panel -->
                <Border Grid.Row="1" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Margin="2">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                    Background="{DynamicResource ThemePanelBg}" Height="28">
                            <TextBlock Text="Memory Dump" Style="{StaticResource PanelHeaderStyle}"/>
                            <TextBlock Text="Address:" FontFamily="Consolas" FontSize="13"
                                       VerticalAlignment="Center" Margin="4,0,4,0"/>
                            <TextBox x:Name="TxtMemAddr" Width="80" FontFamily="Consolas" FontSize="13"
                                     VerticalContentAlignment="Center"/>
                            <TextBlock Text="Size:" FontFamily="Consolas" FontSize="13"
                                       VerticalAlignment="Center" Margin="8,0,4,0"/>
                            <TextBox x:Name="MemSizeBox" Width="50" FontFamily="Consolas" FontSize="13"
                                     Text="256" VerticalContentAlignment="Center"/>
                            <Button Content="Go" Style="{StaticResource ToolBarBtnStyle}" Click="OnMemoryGo"/>
                            <Separator Margin="4,0"/>
                            <Button x:Name="BtnMemEdit" Content="Edit" FontSize="11" Padding="6,2" Click="OnMemEdit"/>
                            <Button x:Name="BtnMemApply" Content="Apply" FontSize="11" Padding="6,2"
                                    Click="OnMemApply" Visibility="Collapsed"/>
                            <Button x:Name="BtnMemCancel" Content="Cancel" FontSize="11" Padding="6,2"
                                    Click="OnMemCancel" Visibility="Collapsed"/>
                        </StackPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                      Background="{DynamicResource ThemeWindowBg}">
                            <StackPanel x:Name="MemoryDumpPanel"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Right: Register Panel (spans full height) -->
            <Border Grid.Column="1" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Margin="2">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="RegisterPanel" Margin="4"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Row 3: Status Bar -->
        <Border Grid.Row="3" Background="{DynamicResource ThemeStatusBarBg}" Padding="8,4">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="StatusText" Text="No plugin loaded"
                               Foreground="White" FontSize="12"/>
                    <TextBlock x:Name="BoardTypeText" Foreground="White" FontSize="12" Margin="16,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
