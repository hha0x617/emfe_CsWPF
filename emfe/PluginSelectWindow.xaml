<Window x:Class="emfe.PluginSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Plugin" Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource ThemeWindowBg}"
        Foreground="{DynamicResource ThemeForeground}">
    <StackPanel Margin="16">
        <TextBlock Text="Multiple plugins found. Select one to load:"
                   FontSize="12" Margin="0,0,0,8"/>
        <ListBox x:Name="PluginList" MinHeight="60" MaxHeight="200" FontFamily="Consolas" FontSize="13"
                 SelectionMode="Single" MouseDoubleClick="OnListDoubleClick"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" IsDefault="True" Padding="20,4" Margin="0,0,6,0" Click="OnOK"/>
            <Button Content="Cancel" IsCancel="True" Padding="20,4" Click="OnCancel"/>
        </StackPanel>
    </StackPanel>
</Window>
