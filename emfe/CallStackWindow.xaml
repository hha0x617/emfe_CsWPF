<Window x:Class="emfe.CallStackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Call Stack" Width="620" Height="380"
        Background="{DynamicResource ThemeWindowBg}"
        Foreground="{DynamicResource ThemeForeground}">
    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    Background="{DynamicResource ThemePanelBg}" Height="40">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="8,0"
                       Foreground="{DynamicResource ThemeDimFg}" FontSize="12"/>
            <Button Content="Refresh" Padding="10,4" Margin="0,6" Click="OnRefresh"/>
            <Button Content="Close" Padding="10,4" Margin="8,6" Click="OnClose"/>
        </StackPanel>
        <ListView x:Name="StackList" FontFamily="Consolas" FontSize="13"
                  Margin="8,8,8,0"
                  MouseDoubleClick="OnListDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="#" Width="40" DisplayMemberBinding="{Binding Index}"/>
                    <GridViewColumn Header="Kind" Width="80" DisplayMemberBinding="{Binding KindText}"/>
                    <GridViewColumn Header="Call PC" Width="90" DisplayMemberBinding="{Binding CallPcText}"/>
                    <GridViewColumn Header="Target PC" Width="90" DisplayMemberBinding="{Binding TargetPcText}"/>
                    <GridViewColumn Header="Return PC" Width="90" DisplayMemberBinding="{Binding ReturnPcText}"/>
                    <GridViewColumn Header="Frame" Width="90" DisplayMemberBinding="{Binding FrameText}"/>
                    <GridViewColumn Header="Label" Width="120" DisplayMemberBinding="{Binding Label}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>
