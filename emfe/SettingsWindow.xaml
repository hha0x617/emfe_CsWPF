<Window x:Class="emfe.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Emulator Settings" Width="600" Height="700"
        Background="{DynamicResource ThemeWindowBg}"
        Foreground="{DynamicResource ThemeForeground}">
    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="16,8,16,16">
            <Button x:Name="BtnOK" Content="OK" Padding="20,6" Margin="0,0,8,0" Click="OnOK"/>
            <Button x:Name="BtnCancel" Content="Cancel" Padding="20,6" Click="OnCancel"/>
        </StackPanel>
        <TabControl x:Name="SettingsTabs" Margin="8,8,8,0" SelectionChanged="OnTabSelectionChanged"/>
    </DockPanel>
</Window>
