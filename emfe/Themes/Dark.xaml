<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="ThemeWindowBg"      Color="#FF1E1E1E"/>
    <SolidColorBrush x:Key="ThemePanelBg"       Color="#FF2D2D30"/>
    <SolidColorBrush x:Key="ThemeControlBg"     Color="#FF3E3E42"/>
    <SolidColorBrush x:Key="ThemeInputBg"       Color="#FF2D2D30"/>
    <SolidColorBrush x:Key="ThemeConsoleBg"     Color="#FF0C0C0C"/>
    <SolidColorBrush x:Key="ThemeForeground"    Color="#FFD4D4D4"/>
    <SolidColorBrush x:Key="ThemeBrightFg"      Color="#FFF0F0F0"/>
    <SolidColorBrush x:Key="ThemeDimFg"         Color="#FF808080"/>
    <SolidColorBrush x:Key="ThemeDisabledFg"    Color="#FF909090"/>
    <SolidColorBrush x:Key="ThemeBorder"        Color="#FF3F3F46"/>
    <SolidColorBrush x:Key="ThemeButtonBorder"  Color="#FF555555"/>
    <SolidColorBrush x:Key="ThemeSeparator"     Color="#FF555555"/>
    <SolidColorBrush x:Key="ThemeAccent"        Color="#FF569CD6"/>
    <SolidColorBrush x:Key="ThemeStatusBarBg"   Color="#FF007ACC"/>
    <SolidColorBrush x:Key="ThemeRegHeaderFg"   Color="#FF4EC9B0"/>
    <SolidColorBrush x:Key="ThemeBreakpointFg"  Color="#FFFF0000"/>
    <SolidColorBrush x:Key="ThemeHighlightedFg" Color="#FFFFFF00"/>
    <SolidColorBrush x:Key="ThemeHighlightFg"   Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ThemeCheckedBg"     Color="#FF264F78"/>
    <SolidColorBrush x:Key="ThemeConsoleFg"     Color="#FF00FF00"/>
    <SolidColorBrush x:Key="ThemeMenuHover"     Color="#FF3E3E42"/>
    <SolidColorBrush x:Key="ThemeListSelection" Color="#FF264F78"/>
    <SolidColorBrush x:Key="ThemeWarningFg"     Color="#FFFFA500"/>
    <SolidColorBrush x:Key="ThemeHighlight"     Color="#FF264F78"/>
    <SolidColorBrush x:Key="ThemeGestureFg"     Color="#FF909090"/>

    <!-- ===== SystemColors overrides for Popup/Menu/ScrollBar default templates ===== -->
    <!-- These keys are referenced by WPF default ControlTemplates that we don't override.
         Overriding here so menus/popups/scrollbars/comboboxes use our dark colors. -->
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"        Color="#FF2D2D30"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"    Color="#FFD4D4D4"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"       Color="#FF2D2D30"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}"  Color="#FF3F3F46"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#FF2D2D30"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}"   Color="#FF3F3F46"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="#FF3F3F46"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}"   Color="#FFF0F0F0"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}"          Color="#FF2D2D30"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}"      Color="#FFF0F0F0"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}"       Color="#FF2D2D30"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#FF264F78"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"     Color="#FF264F78"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}"      Color="#FF808080"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ScrollBarBrushKey}"     Color="#FF2D2D30"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveBorderBrushKey}" Color="#FF3F3F46"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ActiveBorderBrushKey}"   Color="#FF555555"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveCaptionBrushKey}" Color="#FF2D2D30"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveCaptionTextBrushKey}" Color="#FFD4D4D4"/>

    <!-- Color keys (for animations / state changes that bind to colors not brushes) -->
    <Color x:Key="{x:Static SystemColors.WindowColorKey}">#FF2D2D30</Color>
    <Color x:Key="{x:Static SystemColors.WindowTextColorKey}">#FFD4D4D4</Color>
    <Color x:Key="{x:Static SystemColors.ControlColorKey}">#FF2D2D30</Color>
    <Color x:Key="{x:Static SystemColors.ControlTextColorKey}">#FFD4D4D4</Color>
    <Color x:Key="{x:Static SystemColors.HighlightColorKey}">#FF264F78</Color>
    <Color x:Key="{x:Static SystemColors.HighlightTextColorKey}">#FFFFFFFF</Color>
    <Color x:Key="{x:Static SystemColors.MenuColorKey}">#FF2D2D30</Color>
    <Color x:Key="{x:Static SystemColors.MenuTextColorKey}">#FFF0F0F0</Color>
    <Color x:Key="{x:Static SystemColors.MenuHighlightColorKey}">#FF264F78</Color>

</ResourceDictionary>
