<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="ThemeWindowBg"      Color="#FFF5F5F5"/>
    <SolidColorBrush x:Key="ThemePanelBg"       Color="#FFE8E8E8"/>
    <SolidColorBrush x:Key="ThemeControlBg"     Color="#FFD6D6D6"/>
    <SolidColorBrush x:Key="ThemeInputBg"       Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ThemeConsoleBg"     Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ThemeForeground"    Color="#FF1E1E1E"/>
    <SolidColorBrush x:Key="ThemeBrightFg"      Color="#FF000000"/>
    <SolidColorBrush x:Key="ThemeDimFg"         Color="#FF666666"/>
    <SolidColorBrush x:Key="ThemeDisabledFg"    Color="#FF999999"/>
    <SolidColorBrush x:Key="ThemeBorder"        Color="#FFCCCCCC"/>
    <SolidColorBrush x:Key="ThemeButtonBorder"  Color="#FFAAAAAA"/>
    <SolidColorBrush x:Key="ThemeSeparator"     Color="#FFCCCCCC"/>
    <SolidColorBrush x:Key="ThemeAccent"        Color="#FF0066CC"/>
    <SolidColorBrush x:Key="ThemeStatusBarBg"   Color="#FF007ACC"/>
    <SolidColorBrush x:Key="ThemeRegHeaderFg"   Color="#FF008080"/>
    <SolidColorBrush x:Key="ThemeBreakpointFg"  Color="#FFCC0000"/>
    <SolidColorBrush x:Key="ThemeHighlightedFg" Color="#FF996600"/>
    <SolidColorBrush x:Key="ThemeHighlightFg"   Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ThemeCheckedBg"     Color="#FFB8D4F0"/>
    <SolidColorBrush x:Key="ThemeConsoleFg"     Color="#FF006600"/>
    <SolidColorBrush x:Key="ThemeMenuHover"     Color="#FFE0E0E0"/>
    <SolidColorBrush x:Key="ThemeListSelection" Color="#FFD0E8FF"/>
    <SolidColorBrush x:Key="ThemeWarningFg"     Color="#FFCC6600"/>
    <SolidColorBrush x:Key="ThemeHighlight"     Color="#FF0066CC"/>
    <SolidColorBrush x:Key="ThemeGestureFg"     Color="#FF666666"/>

    <!-- ===== SystemColors overrides ===== -->
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"        Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"    Color="#FF1E1E1E"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"       Color="#FFE8E8E8"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}"  Color="#FFF5F5F5"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}"   Color="#FFCCCCCC"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="#FF999999"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}"   Color="#FF1E1E1E"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}"          Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}"      Color="#FF000000"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}"       Color="#FFE8E8E8"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#FFD0E8FF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"     Color="#FFD0E8FF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FF000000"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}"      Color="#FF666666"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ScrollBarBrushKey}"     Color="#FFE8E8E8"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveBorderBrushKey}" Color="#FFCCCCCC"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ActiveBorderBrushKey}"   Color="#FFAAAAAA"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveCaptionBrushKey}" Color="#FFE8E8E8"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveCaptionTextBrushKey}" Color="#FF1E1E1E"/>

    <Color x:Key="{x:Static SystemColors.WindowColorKey}">#FFFFFFFF</Color>
    <Color x:Key="{x:Static SystemColors.WindowTextColorKey}">#FF1E1E1E</Color>
    <Color x:Key="{x:Static SystemColors.ControlColorKey}">#FFE8E8E8</Color>
    <Color x:Key="{x:Static SystemColors.ControlTextColorKey}">#FF1E1E1E</Color>
    <Color x:Key="{x:Static SystemColors.HighlightColorKey}">#FFD0E8FF</Color>
    <Color x:Key="{x:Static SystemColors.HighlightTextColorKey}">#FF000000</Color>
    <Color x:Key="{x:Static SystemColors.MenuColorKey}">#FFFFFFFF</Color>
    <Color x:Key="{x:Static SystemColors.MenuTextColorKey}">#FF000000</Color>
    <Color x:Key="{x:Static SystemColors.MenuHighlightColorKey}">#FFD0E8FF</Color>

</ResourceDictionary>
