<Window x:Class="emfe.EditConditionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Breakpoint Condition" Width="420" Height="220"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource ThemeWindowBg}"
        Foreground="{DynamicResource ThemeForeground}">
    <StackPanel Margin="16">
        <TextBlock x:Name="HeaderText" FontSize="12" Margin="0,0,0,4"/>
        <TextBlock Text="Condition (e.g. D0==0x42, leave empty to clear):"
                   FontSize="11" Margin="0,0,0,4"
                   Foreground="{DynamicResource ThemeDimFg}"/>
        <TextBox x:Name="ConditionBox" FontFamily="Consolas" FontSize="13"
                 Margin="0,0,0,12"
                 VerticalContentAlignment="Center"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" IsDefault="True" Padding="20,4" Margin="0,0,6,0" Click="OnOK"/>
            <Button Content="Cancel" IsCancel="True" Padding="20,4" Click="OnCancel"/>
        </StackPanel>
    </StackPanel>
</Window>
